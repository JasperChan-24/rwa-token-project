# Sepolia RPC and deployment wallet. Never commit real secrets.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/replace-me
SEPOLIA_PRIVATE_KEY=0xreplace-me
ETHERSCAN_API_KEY=replace-me

# Explicit one-time acknowledgement required by `npm run demo:sepolia`.
SEPOLIA_DEMO_CONFIRM=

# Optional public browser address; no secret belongs in a NEXT_PUBLIC_ variable.
NEXT_PUBLIC_PROPERTY_TOKEN_ADDRESS=
