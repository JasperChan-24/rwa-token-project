{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "compile": "hardhat build",
    "postcompile": "node scripts/export-abi.mjs",
    "export:abi": "node scripts/export-abi.mjs",
    "preexport:verification": "hardhat build --build-profile production",
    "export:verification": "node scripts/export-verification-input.mjs",
    "test": "hardhat test",
    "test:foundry": "FOUNDRY_PROFILE=ci forge test --no-match-path 'test-foundry/gas/*.t.sol' -vvv",
    "lint:foundry": "forge fmt --check test-foundry && forge lint test-foundry",
    "test:frontend": "tsx --test frontend-tests/**/*.test.ts",
    "test:e2e": "playwright test",
    "gas:snapshot": "FOUNDRY_PROFILE=ci forge test --match-path 'test-foundry/gas/*.t.sol' --isolate",
    "gas:check": "FOUNDRY_PROFILE=ci forge test --match-path 'test-foundry/gas/*.t.sol' --isolate --gas-snapshot-check=true",
    "slither": "slither contracts/PropertyToken.sol --compile-force-framework foundry --exclude-dependencies --filter-paths '(^|/)(node_modules|lib|contracts/test|test-foundry)(/|$)' --fail-high",
    "coverage": "hardhat test --coverage",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia --build-profile production",
    "check:sepolia": "tsx scripts/check-deployment.ts",
    "demo:sepolia": "tsx scripts/demo-yield-cycle.ts",
    "check:demo": "tsx scripts/check-yield-demo.ts",
    "verify:deployment": "hardhat run scripts/verify-deployment.ts --network sepolia --build-profile production",
    "verify:sepolia": "hardhat verify --network sepolia --build-profile production"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1",
    "@tanstack/react-query": "5.101.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.55.0",
    "wagmi": "3.7.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-network-helpers": "3.0.11",
    "@nomicfoundation/hardhat-node-test-runner": "3.0.17",
    "@nomicfoundation/hardhat-verify": "3.0.21",
    "@nomicfoundation/hardhat-viem": "3.0.9",
    "@nomicfoundation/hardhat-viem-assertions": "3.1.2",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "22.19.15",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.3.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "hardhat": "3.11.0",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "flatted": "3.4.2",
    "picomatch@4.0.3": "4.0.5",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.16"
    },
    "minimatch@10.2.4": {
      "brace-expansion": "5.0.7"
    },
    "@actions/http-client": {
      "undici": "6.27.0"
    },
    "next": {
      "postcss": "8.5.19"
    }
  }
}
